    <worksheet name='Driver Gap'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#1a3a5c' fontname='Arial'>&lt;Sheet Name&gt;</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run fontname='Arial'>Churners go quiet, fewer games over time and longer gaps, yet they win just as often. Churn is disengagement, not frustration.</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='tableau_drivers' name='federated.13ythls1xgtjq01caqyf914u4rhn' />
          </datasources>
          <datasource-dependencies datasource='federated.13ythls1xgtjq01caqyf914u4rhn'>
            <column caption='Gap Size' datatype='real' name='[Calculation_0760593028526083]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='ABS([diff_pct])' />
            </column>
            <column caption='Diff Pct Direction' datatype='string' name='[Calculation_0760593030615044]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [diff_pct] &gt;= 0 THEN &quot;Churners do more&quot; ELSE &quot;Churners do less&quot; END' />
            </column>
            <column caption='Diff Pct' datatype='real' default-format='p0%' name='[diff_pct]' role='measure' type='quantitative' />
            <column caption='Metric' datatype='string' name='[metric]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_0760593030615044]' derivation='None' name='[none:Calculation_0760593030615044:nk]' pivot='key' type='nominal' />
            <column-instance column='[metric]' derivation='None' name='[none:metric:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_0760593028526083]' derivation='Sum' name='[sum:Calculation_0760593028526083:qk]' pivot='key' type='quantitative' />
            <column-instance column='[diff_pct]' derivation='Sum' name='[sum:diff_pct:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <computed-sort column='[federated.13ythls1xgtjq01caqyf914u4rhn].[none:metric:nk]' direction='DESC' using='[federated.13ythls1xgtjq01caqyf914u4rhn].[sum:Calculation_0760593028526083:qk]' />
