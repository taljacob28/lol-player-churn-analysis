    <worksheet name='Churn by Role'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#1a3a5c' fontname='Arial'>&lt;Sheet Name&gt;</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run fontname='Arial'>Churn is highest for Jungle and Support, lowest for Mid. A signal for role focused retention.</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
